# ════════════════════════════════════════════════════════════════════
#  Lamp Generator — environment variables
#  Copy this file to `.env` and fill in real values.
#  NEVER commit the real `.env` — it is gitignored.
# ════════════════════════════════════════════════════════════════════

# ── Telegram bot ────────────────────────────────────────────────────
# Get these from @BotFather (token) and from @userinfobot (your chat_id).
TELEGRAM_BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=376791080

# ── Server ──────────────────────────────────────────────────────────
PORT=3000
# Comma-separated list of allowed origins (the URL of your deployed frontend).
# In dev, Vite runs on http://localhost:5173 — keep it here.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Public Bearer token that the frontend must send with every /api/* request.
# Generate any random string, e.g. `openssl rand -hex 32`.
# This is NOT a security boundary (it lives in the bundled JS) — it only
# prevents random strangers from hitting your endpoint directly.
PUBLIC_API_KEY=change-me-to-a-random-string